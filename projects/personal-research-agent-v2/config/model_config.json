{
  "fast_model": "gemini-2.5-flash",
  "quality_model": "gemini-2.5-pro",
  "reasoning_model": "deepseek/deepseek-r1",
  "reasoning_provider": "openrouter",
  "reasoning_base_url": "https://openrouter.ai/api/v1",
  "reasoning_api_env": "OPENROUTER_API_KEY",
  "fallback_to_quality_on_reasoning_error": true,
  "enforce_reasoning_preflight": true,
  "warn_on_reasoning_fallback": true,
  "hard_fail_on_quality_gate": false,
  "temperature": 0,
  "max_results_per_query": 6,
  "max_num_turns": 2,
  "max_items_per_section": 4,
  "next_weekend_days": 2,
  "reasoning_primary_model": "deepseek/deepseek-r1",
  "reasoning_fallback_models": [
    "openai/gpt-5-mini",
    "openai/gpt-5.4-mini"
  ],
  "routing_policy": "quality_first",
  "model_failover_max_retries": 1,
  "model_request_timeout_seconds": 45,
  "news_max_age_days": 7,
  "events_max_future_days": 21,
  "bitcoin_technical_max_age_days": 60,
  "stale_suspect_date_conf_threshold": 0.55,
  "bitcoin_technical_missing_date_max_issue_gap": 500
}